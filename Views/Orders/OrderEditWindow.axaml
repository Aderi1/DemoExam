<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DemoExam.Views.Orders.OrderEditWindow"
        Title="Заказ"
        Width="700"
        Height="800"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer>

        <StackPanel Margin="20"
                    Spacing="10">

            <TextBlock Text="Артикул товара"/>
            <ComboBox Name="ProductComboBox"/>

            <TextBlock Text="Клиент"/>
            <ComboBox Name="UserComboBox"/>

            <TextBlock Text="Пункт выдачи"/>
            <ComboBox Name="PickupPointComboBox"/>

            <TextBlock Text="Дата заказа"/>
            <DatePicker Name="OrderDatePicker"/>

            <TextBlock Text="Дата доставки"/>
            <DatePicker Name="DeliveryDatePicker"/>

            <TextBlock Text="Количество"/>
            <TextBox Name="QuantityTextBox"/>

            <TextBlock Text="Статус"/>
            <ComboBox Name="StatusComboBox"/>

            <TextBlock Text="Код получения"/>
            <TextBox Name="ReceiveCodeTextBox"/>

            <TextBlock Name="ErrorTextBlock"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       IsVisible="False"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="10">

                <Button Name="SaveButton"
                        Content="Сохранить"
                        Width="120"
                        Click="SaveButton_Click"/>

                <Button Name="CancelButton"
                        Content="Отмена"
                        Width="120"
                        Click="CancelButton_Click"/>

            </StackPanel>

        </StackPanel>

    </ScrollViewer>

</Window>
