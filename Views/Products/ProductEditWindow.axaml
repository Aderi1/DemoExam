<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DemoExam.Views.Products.ProductEditWindow"
        Title="Товар"
        Width="700"
        Height="800"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer>

        <StackPanel Margin="20"
                    Spacing="10">

            <TextBlock Text="Артикул"/>
            <TextBox Name="ArticleTextBox"/>

            <TextBlock Text="Наименование"/>
            <TextBox Name="NameTextBox"/>

            <TextBlock Text="Единица измерения"/>
            <TextBox Name="UnitTextBox"/>

            <TextBlock Text="Цена"/>
            <TextBox Name="PriceTextBox"/>

            <TextBlock Text="Поставщик"/>
            <ComboBox Name="SupplierComboBox"/>

            <TextBlock Text="Производитель"/>
            <ComboBox Name="ManufacturerComboBox"/>

            <TextBlock Text="Категория"/>
            <ComboBox Name="CategoryComboBox"/>

            <TextBlock Text="Скидка"/>
            <TextBox Name="DiscountTextBox"/>

            <TextBlock Text="Количество"/>
            <TextBox Name="QuantityTextBox"/>

            <TextBlock Text="Описание"/>
            <TextBox Name="DescriptionTextBox"
                     AcceptsReturn="True"
                     Height="120"/>

            <TextBlock Text="Фото"/>
            <TextBox Name="PhotoTextBox"/>

            <Button Name="SaveButton"
                    Content="Сохранить"
                    Click="SaveButton_Click"/>

        </StackPanel>

    </ScrollViewer>

</Window>